# Required — Google Cloud project with "Places API (New)" and "Maps JavaScript API"
# enabled, key restricted to your site's HTTP referrer.
VITE_GOOGLE_MAPS_API_KEY=

# Optional — leave both blank to run in local-only mode (localStorage,
# single device/browser). Fill in a free Supabase project's values to get
# shareable, multi-device permits with real photo hosting.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
